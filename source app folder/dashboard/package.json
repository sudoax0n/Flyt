{
  "name": "dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"node server.js\" \"vite\"",
    "dev:frontend": "vite",
    "dev:server": "node server.js",
    "build": "vite build",
    "lint": "eslint .",
    "lint:backend": "eslint server.js server-utils.js tests",
    "test": "npm run test:server",
    "test:server": "node --test tests/*.test.js",
    "check": "npm run lint && npm run test:server && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.6.0",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1"
  }
}
